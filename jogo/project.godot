; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Jogo de Arquitetura"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

SignalBus="*res://scripts/autoloads/signal_bus.gd"
GameManager="*res://scripts/autoloads/game_manager.gd"
AudioManager="*res://scenes/autoloads/audio_manager.tscn"
GameFacade="*res://scripts/autoloads/game_facade.gd"
AchievementManager="*res://scripts/autoloads/achievement_manager.gd"
StudentProfileRegistry="*res://scripts/resources/student_profile_registry.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[dotnet]

project/assembly_name="Jogo de Arquitetura"

[gui]

; Canvas de referência dobrou de 320x180 para 640x360 (mesma proporção 16:9);
; sem isso, toda fonte/Control da UI renderiza na metade do tamanho visual
; de antes, já que a janela final (1280x720) não mudou — só o fator de
; stretch caiu de 4x para 2x.
theme/default_font_size=32

